# ----- Mail (free-week form) -----
# Sign up at https://resend.com (free 3,000 emails/mo) and paste the API key below.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives form submissions. Defaults to info@jiujitsuacademy.sk.
MAIL_TO=info@jiujitsuacademy.sk

# "From" header. Must be a verified domain inside Resend — see MIGRATION.md.
# If domain verification isn't done yet, you can use Resend's onboarding sender:
# MAIL_FROM="JJAB <onboarding@resend.dev>"
MAIL_FROM="JJAB Website <no-reply@jiujitsuacademy.sk>"
